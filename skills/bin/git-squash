#!/usr/bin/env bash
# git-squash — Interactive rebase helper with smart commit count detection.
# Usage: git-squash [COUNT] [--help]

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && GREEN='' YELLOW='' CYAN='' NC=''

usage() {
    echo "Usage: git-squash [COUNT] [OPTIONS]"
    echo ""
    echo "Interactive rebase helper."
    echo ""
    echo "If COUNT is not specified, auto-detects the number of commits"
    echo "ahead of the remote tracking branch (or defaults to showing recent commits)."
    echo ""
    echo "Options:"
    echo "  --help, -h    Show this help message"
    echo ""
    echo "Examples:"
    echo "  git-squash        # Auto-detect unpushed commits"
    echo "  git-squash 5      # Rebase last 5 commits"
    exit 0
}

COUNT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) usage ;;
        -*) echo "Unknown option: $1"; usage ;;
        *) COUNT="$1" ;;
    esac
    shift
done

# Must be in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "${YELLOW}Not in a git repository.${NC}"
    exit 1
fi

if [[ -z "$COUNT" ]]; then
    # Try to auto-detect unpushed commits
    TRACKING=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")
    
    if [[ -n "$TRACKING" ]]; then
        COUNT=$(git rev-list --count "${TRACKING}..HEAD" 2>/dev/null || echo "0")
        if [[ "$COUNT" -eq 0 ]]; then
            echo "${YELLOW}No unpushed commits found.${NC}"
            echo ""
            echo "Specify a count manually: git-squash <number>"
            exit 0
        fi
        echo "${CYAN}Found $COUNT unpushed commit(s) ahead of $TRACKING${NC}"
    else
        # No tracking branch — show recent commits and ask
        echo "${CYAN}No tracking branch found. Recent commits:${NC}"
        echo ""
        git log --oneline -15
        echo ""
        printf "How many commits to rebase? "
        read -r COUNT
        if [[ -z "$COUNT" || ! "$COUNT" =~ ^[0-9]+$ ]]; then
            echo "Invalid number."
            exit 1
        fi
    fi
fi

echo ""
echo "${GREEN}Commits to rebase:${NC}"
git log --oneline -"$COUNT"
echo ""
printf "${YELLOW}Proceed with interactive rebase of $COUNT commit(s)? [Y/n]: ${NC}"
read -r confirm
[[ "$confirm" == [nN] ]] && exit 0

git rebase -i "HEAD~$COUNT"
