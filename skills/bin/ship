#!/usr/bin/env bash
# ship — Tar a directory, SCP it to a remote host, and clean up.
# Usage: ship <path> <user@host:dest> [--help]

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && GREEN='' YELLOW='' CYAN='' NC=''

usage() {
    echo "Usage: ship <path> <user@host[:dest]> [OPTIONS]"
    echo ""
    echo "Tar a file or directory, SCP it to a remote host, and clean up the local tar."
    echo ""
    echo "Arguments:"
    echo "  <path>              Local file or directory to ship"
    echo "  <user@host[:dest]>  Remote destination (default dest: ~/)"
    echo ""
    echo "Options:"
    echo "  --keep, -k    Keep the local tar file after shipping"
    echo "  --help, -h    Show this help message"
    echo ""
    echo "Examples:"
    echo "  ship ~/.config/nvim craigyang@192.168.54.131"
    echo "  ship ./project craigyang@192.168.54.131:~/backups/"
    exit 0
}

LOCAL_PATH=""
REMOTE=""
KEEP=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --keep|-k) KEEP=true ;;
        --help|-h) usage ;;
        -*) echo "Unknown option: $1"; usage ;;
        *)
            if [[ -z "$LOCAL_PATH" ]]; then
                LOCAL_PATH="$1"
            elif [[ -z "$REMOTE" ]]; then
                REMOTE="$1"
            else
                echo "Too many arguments."; usage
            fi
            ;;
    esac
    shift
done

if [[ -z "$LOCAL_PATH" || -z "$REMOTE" ]]; then
    echo "${YELLOW}Both <path> and <user@host> are required.${NC}"
    usage
fi

if [[ ! -e "$LOCAL_PATH" ]]; then
    echo "${YELLOW}Path not found: $LOCAL_PATH${NC}"
    exit 1
fi

# Parse remote
if [[ "$REMOTE" == *:* ]]; then
    REMOTE_HOST="${REMOTE%%:*}"
    REMOTE_DEST="${REMOTE#*:}"
else
    REMOTE_HOST="$REMOTE"
    REMOTE_DEST="~/"
fi

# Create tar
BASENAME=$(basename "$LOCAL_PATH")
TAR_NAME="${BASENAME}.tar.gz"

echo "${CYAN}Packing:${NC} $LOCAL_PATH → $TAR_NAME"
tar czf "$TAR_NAME" -C "$(dirname "$LOCAL_PATH")" "$BASENAME"

# SCP
echo "${CYAN}Shipping:${NC} $TAR_NAME → ${REMOTE_HOST}:${REMOTE_DEST}"
scp "$TAR_NAME" "${REMOTE_HOST}:${REMOTE_DEST}${TAR_NAME}"

# Cleanup
if ! $KEEP; then
    rm "$TAR_NAME"
    echo "${GREEN}✓ Shipped and cleaned up.${NC}"
else
    echo "${GREEN}✓ Shipped. Local tar kept: $TAR_NAME${NC}"
fi
