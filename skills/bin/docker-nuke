#!/usr/bin/env bash
# docker-nuke — Stop & remove all Docker containers, optionally remove images, and prune.
# Usage: docker-nuke [--images] [--dry-run] [--help]

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && RED='' GREEN='' YELLOW='' NC=''

usage() {
    echo "Usage: docker-nuke [OPTIONS]"
    echo ""
    echo "Stop and remove all Docker containers, then prune the system."
    echo ""
    echo "Options:"
    echo "  --images, -i    Also remove all Docker images"
    echo "  --volumes, -v   Also prune volumes (DANGEROUS)"
    echo "  --dry-run, -n   Show what would be done without doing it"
    echo "  --help, -h      Show this help message"
    exit 0
}

REMOVE_IMAGES=false
REMOVE_VOLUMES=false
DRY_RUN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --images|-i) REMOVE_IMAGES=true ;;
        --volumes|-v) REMOVE_VOLUMES=true ;;
        --dry-run|-n) DRY_RUN=true ;;
        --help|-h) usage ;;
        *) echo "Unknown option: $1"; usage ;;
    esac
    shift
done

run() {
    if $DRY_RUN; then
        echo "${YELLOW}[dry-run]${NC} $*"
    else
        echo "${GREEN}→${NC} $*"
        eval "$@"
    fi
}

# Stop all running containers
RUNNING=$(docker ps -q 2>/dev/null)
if [[ -n "$RUNNING" ]]; then
    echo "${RED}Stopping all running containers...${NC}"
    run "docker stop $RUNNING"
else
    echo "${GREEN}No running containers.${NC}"
fi

# Remove all containers
ALL=$(docker ps -aq 2>/dev/null)
if [[ -n "$ALL" ]]; then
    echo "${RED}Removing all containers...${NC}"
    run "docker rm -f $ALL"
else
    echo "${GREEN}No containers to remove.${NC}"
fi

# Remove all images
if $REMOVE_IMAGES; then
    IMAGES=$(docker images -q 2>/dev/null)
    if [[ -n "$IMAGES" ]]; then
        echo "${RED}Removing all images...${NC}"
        run "docker rmi -f $IMAGES"
    else
        echo "${GREEN}No images to remove.${NC}"
    fi
fi

# Prune
echo "${YELLOW}Pruning system...${NC}"
if $REMOVE_VOLUMES; then
    run "docker system prune -af --volumes"
else
    run "docker system prune -af"
fi

echo "${GREEN}Done!${NC}"
