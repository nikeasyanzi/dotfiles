#!/usr/bin/env bash
# grab — Pick a recent file from ~/Downloads and move it to the current directory.
# Usage: grab [PATTERN] [--copy] [--help]

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && GREEN='' YELLOW='' CYAN='' NC=''

DOWNLOADS_DIR="$HOME/Downloads"
COPY_MODE=false
PATTERN=""

usage() {
    echo "Usage: grab [PATTERN] [OPTIONS]"
    echo ""
    echo "Pick a recent file from ~/Downloads and move it to the current directory."
    echo ""
    echo "Arguments:"
    echo "  PATTERN         Filter files by name (glob or substring)"
    echo ""
    echo "Options:"
    echo "  --copy, -c      Copy instead of move"
    echo "  --help, -h      Show this help message"
    echo ""
    echo "Examples:"
    echo "  grab                  # Interactive pick from 15 most recent files"
    echo "  grab .env             # Move the most recent .env file"
    echo "  grab '*.tar.gz' -c   # Copy the most recent .tar.gz file"
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --copy|-c) COPY_MODE=true ;;
        --help|-h) usage ;;
        -*) echo "Unknown option: $1"; usage ;;
        *) PATTERN="$1" ;;
    esac
    shift
done

# Check if fzf is available for interactive selection
HAS_FZF=false
command -v fzf &>/dev/null && HAS_FZF=true

# Get recent files from Downloads
if [[ -n "$PATTERN" ]]; then
    # Filter by pattern
    mapfile -t FILES < <(find "$DOWNLOADS_DIR" -maxdepth 1 -type f -name "*${PATTERN}*" -print0 | xargs -0 ls -t 2>/dev/null | head -15)
else
    mapfile -t FILES < <(ls -t "$DOWNLOADS_DIR" 2>/dev/null | head -15)
    # Prefix with full path
    FILES=("${FILES[@]/#/$DOWNLOADS_DIR/}")
fi

# Filter to only existing files
VALID_FILES=()
for f in "${FILES[@]}"; do
    [[ -f "$f" ]] && VALID_FILES+=("$f")
done

if [[ ${#VALID_FILES[@]} -eq 0 ]]; then
    echo "${YELLOW}No files found in $DOWNLOADS_DIR${NC}"
    [[ -n "$PATTERN" ]] && echo "  Pattern: *${PATTERN}*"
    exit 1
fi

# If only one match, use it directly
if [[ ${#VALID_FILES[@]} -eq 1 ]]; then
    SELECTED="${VALID_FILES[0]}"
elif $HAS_FZF; then
    SELECTED=$(printf '%s\n' "${VALID_FILES[@]}" | sed "s|$DOWNLOADS_DIR/||" | fzf --prompt="Select file: " --height=20)
    SELECTED="$DOWNLOADS_DIR/$SELECTED"
else
    echo "${CYAN}Recent files in ~/Downloads:${NC}"
    i=1
    for f in "${VALID_FILES[@]}"; do
        echo "  $i) $(basename "$f")"
        ((i++))
    done
    echo ""
    printf "Select file [1-${#VALID_FILES[@]}]: "
    read -r choice
    if [[ "$choice" -ge 1 && "$choice" -le ${#VALID_FILES[@]} ]] 2>/dev/null; then
        SELECTED="${VALID_FILES[$((choice-1))]}"
    else
        echo "Invalid selection."
        exit 1
    fi
fi

BASENAME=$(basename "$SELECTED")
DEST="$PWD/$BASENAME"

# Check if destination already exists
if [[ -e "$DEST" ]]; then
    printf "${YELLOW}$BASENAME already exists in current directory. Overwrite? [y/N]: ${NC}"
    read -r confirm
    [[ "$confirm" != [yY] ]] && exit 0
fi

if $COPY_MODE; then
    cp "$SELECTED" "$DEST"
    echo "${GREEN}Copied${NC} $BASENAME → $PWD/"
else
    mv "$SELECTED" "$DEST"
    echo "${GREEN}Moved${NC} $BASENAME → $PWD/"
fi
