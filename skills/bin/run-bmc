#!/usr/bin/env bash
# run-bmc — Launch QEMU with OpenBMC image and standard port forwarding.
# Usage: run-bmc <image.mtd> [--help]

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && GREEN='' YELLOW='' CYAN='' NC=''

usage() {
    echo "Usage: run-bmc <image.mtd> [OPTIONS]"
    echo ""
    echo "Launch QEMU with an OpenBMC MTD image and standard port forwarding."
    echo ""
    echo "Port forwarding:"
    echo "  SSH:   localhost:2222 → :22"
    echo "  HTTPS: localhost:2443 → :443"
    echo "  IPMI:  localhost:2623 → :623 (UDP)"
    echo ""
    echo "Arguments:"
    echo "  <image.mtd>      Path to the .mtd firmware image"
    echo ""
    echo "Options:"
    echo "  -m, --machine MACHINE   QEMU machine type (default: romulus-bmc)"
    echo "  --memory MEM            Memory in MB (default: 256)"
    echo "  --ssh-port PORT         Local SSH port (default: 2222)"
    echo "  --help, -h              Show this help message"
    echo ""
    echo "After boot, connect with:"
    echo "  ssh root@localhost -p 2222"
    exit 0
}

IMAGE=""
MACHINE="romulus-bmc"
MEMORY="256"
SSH_PORT="2222"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -m|--machine) shift; MACHINE="$1" ;;
        --memory) shift; MEMORY="$1" ;;
        --ssh-port) shift; SSH_PORT="$1" ;;
        --help|-h) usage ;;
        -*) echo "Unknown option: $1"; usage ;;
        *) IMAGE="$1" ;;
    esac
    shift
done

if [[ -z "$IMAGE" ]]; then
    # Look for .mtd files in current directory
    shopt -s nullglob
    MTD_FILES=(*.mtd *.static.mtd)
    shopt -u nullglob
    if [[ ${#MTD_FILES[@]} -eq 1 ]]; then
        IMAGE="${MTD_FILES[0]}"
        echo "${CYAN}Auto-detected image:${NC} $IMAGE"
    elif [[ ${#MTD_FILES[@]} -gt 1 ]]; then
        echo "${CYAN}Multiple MTD images found:${NC}"
        i=1
        for f in "${MTD_FILES[@]}"; do
            echo "  $i) $f"
            ((i++))
        done
        printf "Select [1-${#MTD_FILES[@]}]: "
        read -r choice
        IMAGE="${MTD_FILES[$((choice-1))]}"
    else
        echo "${YELLOW}No MTD image specified or found.${NC}"
        usage
    fi
fi

if [[ ! -f "$IMAGE" ]]; then
    echo "${YELLOW}Image not found: $IMAGE${NC}"
    exit 1
fi

# Determine QEMU binary
QEMU_BIN="qemu-system-arm"
if command -v qemu-system-aarch64 &>/dev/null; then
    QEMU_BIN="qemu-system-aarch64"
elif [[ -x "./qemu-system-arm" ]]; then
    QEMU_BIN="./qemu-system-arm"
fi

HTTPS_PORT=$((SSH_PORT + 221))  # 2443
IPMI_PORT=$((SSH_PORT + 401))   # 2623

echo "${GREEN}Launching OpenBMC QEMU${NC}"
echo "  Machine:  $MACHINE"
echo "  Memory:   ${MEMORY}MB"
echo "  Image:    $IMAGE"
echo "  SSH:      localhost:$SSH_PORT"
echo "  HTTPS:    localhost:$HTTPS_PORT"
echo "  IPMI:     localhost:$IPMI_PORT"
echo ""

$QEMU_BIN \
    -m "$MEMORY" \
    -M "$MACHINE" \
    -nographic \
    -drive "file=${IMAGE},format=raw,if=mtd" \
    -net nic \
    -net "user,hostfwd=:127.0.0.1:${SSH_PORT}-:22,hostfwd=:127.0.0.1:${HTTPS_PORT}-:443,hostfwd=udp:127.0.0.1:${IPMI_PORT}-:623,hostname=qemu"
