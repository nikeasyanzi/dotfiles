#!/usr/bin/env bash
# brew-maintain — Run the full Homebrew maintenance cycle.
# Usage: brew-maintain [--dry-run] [--help]

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && GREEN='' YELLOW='' CYAN='' NC=''

usage() {
    echo "Usage: brew-maintain [OPTIONS]"
    echo ""
    echo "Run the full Homebrew maintenance cycle:"
    echo "  1. brew update"
    echo "  2. brew upgrade"
    echo "  3. brew autoremove"
    echo "  4. brew cleanup"
    echo ""
    echo "Options:"
    echo "  --dry-run, -n   Show what would be done"
    echo "  --help, -h      Show this help message"
    exit 0
}

DRY_RUN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run|-n) DRY_RUN=true ;;
        --help|-h) usage ;;
        *) echo "Unknown option: $1"; usage ;;
    esac
    shift
done

step() {
    echo ""
    echo "${CYAN}[$1/4]${NC} ${GREEN}$2${NC}"
    if $DRY_RUN; then
        echo "${YELLOW}[dry-run]${NC} $2"
    else
        eval "$2"
    fi
}

step 1 "brew update"
step 2 "brew upgrade"
step 3 "brew autoremove"
step 4 "brew cleanup"

echo ""
echo "${GREEN}✓ Homebrew maintenance complete!${NC}"
