#!/usr/bin/env bash
# dc — Docker Compose wrapper with auto file detection.
# Usage: dc [up|down|restart|build|logs|ps] [EXTRA_ARGS...] [--help]

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && GREEN='' YELLOW='' NC=''

usage() {
    echo "Usage: dc <command> [EXTRA_ARGS...]"
    echo ""
    echo "Docker Compose wrapper that auto-detects the compose file."
    echo ""
    echo "Commands:"
    echo "  up        Start services (detached by default)"
    echo "  down      Stop and remove services"
    echo "  restart   Restart services"
    echo "  build     Build services"
    echo "  logs      Show logs (follows by default)"
    echo "  ps        List running services"
    echo "  pull      Pull service images"
    echo "  exec      Execute command in a service"
    echo "  *         Any other docker compose command"
    echo ""
    echo "Options:"
    echo "  -f FILE   Specify compose file explicitly"
    echo "  --help    Show this help message"
    echo ""
    echo "Auto-detects: docker-compose.yml, docker-compose.yaml, compose.yml, compose.yaml"
    exit 0
}

[[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]] && usage

# Auto-detect compose file
COMPOSE_FILE=""
EXPLICIT_FILE=false

if [[ "$1" == "-f" ]]; then
    COMPOSE_FILE="$2"
    EXPLICIT_FILE=true
    shift 2
fi

if ! $EXPLICIT_FILE; then
    for candidate in docker-compose.yml docker-compose.yaml compose.yml compose.yaml; do
        if [[ -f "$candidate" ]]; then
            COMPOSE_FILE="$candidate"
            break
        fi
    done
fi

if [[ -z "$COMPOSE_FILE" ]]; then
    echo "${YELLOW}No compose file found in current directory.${NC}"
    echo "Looked for: docker-compose.yml, docker-compose.yaml, compose.yml, compose.yaml"
    exit 1
fi

echo "${GREEN}Using${NC} $COMPOSE_FILE"

CMD="$1"
shift

# Determine the correct docker compose command
DOCKER_COMPOSE=(docker compose)
if ! docker compose version &>/dev/null 2>&1; then
    DOCKER_COMPOSE=(docker-compose)
fi

case "$CMD" in
    up)
        "${DOCKER_COMPOSE[@]}" -f "$COMPOSE_FILE" up -d "$@"
        ;;
    down)
        "${DOCKER_COMPOSE[@]}" -f "$COMPOSE_FILE" down "$@"
        ;;
    restart)
        "${DOCKER_COMPOSE[@]}" -f "$COMPOSE_FILE" restart "$@"
        ;;
    build)
        "${DOCKER_COMPOSE[@]}" -f "$COMPOSE_FILE" build "$@"
        ;;
    logs)
        "${DOCKER_COMPOSE[@]}" -f "$COMPOSE_FILE" logs -f "$@"
        ;;
    ps)
        "${DOCKER_COMPOSE[@]}" -f "$COMPOSE_FILE" ps "$@"
        ;;
    *)
        "${DOCKER_COMPOSE[@]}" -f "$COMPOSE_FILE" "$CMD" "$@"
        ;;
esac
