#!/usr/bin/env bash
# git-kickstart — Initialize a repo, make first commit, set remote, and push.
# Usage: git-kickstart [REPO_NAME] [--help]

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && GREEN='' YELLOW='' CYAN='' NC=''

GITHUB_USER="nikeasyanzi"

usage() {
    echo "Usage: git-kickstart [REPO_NAME] [OPTIONS]"
    echo ""
    echo "Initialize a git repo, make the first commit, set GitHub remote, and push."
    echo ""
    echo "If REPO_NAME is not specified, uses the current directory name."
    echo "GitHub user: $GITHUB_USER"
    echo ""
    echo "Options:"
    echo "  --https       Use HTTPS instead of SSH for remote"
    echo "  --no-push     Don't push (just init and commit)"
    echo "  --help, -h    Show this help message"
    exit 0
}

USE_SSH=true
DO_PUSH=true
REPO_NAME=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --https) USE_SSH=false ;;
        --no-push) DO_PUSH=false ;;
        --help|-h) usage ;;
        -*) echo "Unknown option: $1"; usage ;;
        *) REPO_NAME="$1" ;;
    esac
    shift
done

[[ -z "$REPO_NAME" ]] && REPO_NAME=$(basename "$PWD")

if $USE_SSH; then
    REMOTE_URL="git@github.com:${GITHUB_USER}/${REPO_NAME}.git"
else
    REMOTE_URL="https://github.com/${GITHUB_USER}/${REPO_NAME}.git"
fi

echo "${CYAN}Initializing repo:${NC} $REPO_NAME"
echo "${CYAN}Remote:${NC} $REMOTE_URL"
echo ""

# Init if not already a git repo
if [[ ! -d ".git" ]]; then
    echo "${GREEN}→${NC} git init"
    git init
else
    echo "${YELLOW}Already a git repo, skipping init.${NC}"
fi

# Create .gitignore if it doesn't exist
if [[ ! -f ".gitignore" ]]; then
    echo "${GREEN}→${NC} Creating default .gitignore"
    cat > .gitignore << 'EOF'
.DS_Store
*.pyc
__pycache__/
.venv/
node_modules/
.env
*.log
EOF
fi

# Stage and commit
echo "${GREEN}→${NC} git add -A"
git add -A

if git diff --cached --quiet 2>/dev/null; then
    echo "${YELLOW}Nothing to commit.${NC}"
else
    echo "${GREEN}→${NC} git commit -m 'initial commit'"
    git commit -m "initial commit"
fi

# Set branch name
echo "${GREEN}→${NC} git branch -M main"
git branch -M main

# Set remote
if git remote get-url origin &>/dev/null 2>&1; then
    echo "${YELLOW}Remote 'origin' already exists, updating URL.${NC}"
    git remote set-url origin "$REMOTE_URL"
else
    echo "${GREEN}→${NC} git remote add origin $REMOTE_URL"
    git remote add origin "$REMOTE_URL"
fi

# Push
if $DO_PUSH; then
    echo "${GREEN}→${NC} git push -u origin main"
    git push -u origin main
    echo ""
    echo "${GREEN}✓ Done! Repo pushed to ${REMOTE_URL}${NC}"
else
    echo ""
    echo "${GREEN}✓ Done! Run 'git push -u origin main' when ready.${NC}"
fi
