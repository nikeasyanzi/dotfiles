#!/usr/bin/env bash
# fmt-cpp — Run clang-format in-place on C/C++ files.
# Usage: fmt-cpp [FILES...] [--check] [--help]

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'
[[ -n "${NO_COLOR:-}" ]] && GREEN='' YELLOW='' NC=''

usage() {
    echo "Usage: fmt-cpp [FILES...] [OPTIONS]"
    echo ""
    echo "Run clang-format in-place on C/C++ files."
    echo ""
    echo "If no files are specified, formats all .c, .cpp, .h, .hpp files"
    echo "in the current directory (non-recursive)."
    echo ""
    echo "Options:"
    echo "  -r, --recursive   Include files in subdirectories"
    echo "  --check           Check only (don't modify, exit 1 if changes needed)"
    echo "  --help, -h        Show this help message"
    exit 0
}

CHECK_ONLY=false
RECURSIVE=false
EXPLICIT_FILES=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --check) CHECK_ONLY=true ;;
        -r|--recursive) RECURSIVE=true ;;
        --help|-h) usage ;;
        -*) echo "Unknown option: $1"; usage ;;
        *) EXPLICIT_FILES+=("$1") ;;
    esac
    shift
done

if ! command -v clang-format &>/dev/null; then
    echo "${YELLOW}clang-format not found. Install with: brew install clang-format${NC}"
    exit 1
fi

# Collect files
if [[ ${#EXPLICIT_FILES[@]} -gt 0 ]]; then
    FILES=("${EXPLICIT_FILES[@]}")
else
    if $RECURSIVE; then
        mapfile -t FILES < <(find . -type f \( -name '*.c' -o -name '*.cpp' -o -name '*.h' -o -name '*.hpp' -o -name '*.cc' -o -name '*.cxx' \) | sort)
    else
        FILES=()
        shopt -s nullglob
        for ext in c cpp h hpp cc cxx; do
            for f in *.$ext; do
                FILES+=("$f")
            done
        done
        shopt -u nullglob
    fi
fi

if [[ ${#FILES[@]} -eq 0 ]]; then
    echo "${YELLOW}No C/C++ files found.${NC}"
    exit 0
fi

echo "${GREEN}Formatting ${#FILES[@]} file(s)...${NC}"

if $CHECK_ONLY; then
    clang-format --dry-run -Werror "${FILES[@]}"
    echo "${GREEN}✓ All files properly formatted.${NC}"
else
    for f in "${FILES[@]}"; do
        echo "  ${GREEN}→${NC} $f"
        clang-format -i "$f"
    done
    echo "${GREEN}✓ Done!${NC}"
fi
